rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to check if user is authenticated and is the owner of the user path
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper to check if the user is the specified Admin
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'WZbfGiIXCjZLGfr7WOiANyYlXLm1';
    }

    // Helper to validate document IDs
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['email', 'displayName', 'createdAt', 'role'])
        && data.keys().size() == 4
        && data.email is string
        && data.email.size() > 0
        && data.email.size() <= 256
        && data.displayName is string
        && data.displayName.size() > 0
        && data.displayName.size() <= 256
        && data.createdAt is string
        && data.createdAt.size() > 0
        && data.createdAt.size() <= 100
        && data.role is string
        && data.role == 'client';
    }

    function isValidFile(data, userId) {
      return data.keys().hasAll(['id', 'name', 'size', 'type', 'ownerId', 'uploadedAt'])
        && data.keys().size() == 6
        && data.id is string
        && data.id.size() > 0
        && data.id.size() <= 128
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 512
        && data.size is number
        && data.size >= 0
        && data.type is string
        && data.type.size() > 0
        && data.type.size() <= 128
        && data.ownerId is string
        && data.ownerId == userId
        && data.uploadedAt is string
        && data.uploadedAt.size() > 0
        && data.uploadedAt.size() <= 100;
    }

    match /users/{userId} {
      allow get: if (isOwner(userId) || isAdmin()) && isValidId(userId);
      allow list: if isAdmin();
      allow create, update: if isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming());
      allow delete: if isOwner(userId) && isValidId(userId);

      match /files/{fileId} {
        allow get: if (isOwner(userId) || isAdmin()) && isValidId(userId) && isValidId(fileId);
        allow list: if (isOwner(userId) || isAdmin()) && isValidId(userId);
        allow create, update: if isOwner(userId) && isValidId(userId) && isValidId(fileId) && isValidFile(incoming(), userId);
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(fileId);
      }
    }
  }
}
